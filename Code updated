library(shiny)
library(DT)

ui <- fluidPage(
  titlePanel("CSV Viewer & Analyzer App"),
  
  sidebarLayout(
    sidebarPanel(
      fileInput(
        "csv_file",
        "Upload a CSV file",
        accept = c(".csv")
      ),
      
      checkboxInput("header", "File has header", TRUE),
      
      radioButtons(
        "sep",
        "Separator",
        choices = c(
          Comma = ",",
          Semicolon = ";",
          Tab = "\t"
        ),
        selected = ","
      ),
      
      # NEW: Column selector
      uiOutput("column_selector")
    ),
    
    mainPanel(
      tabsetPanel(
        tabPanel("Data Table", DTOutput("data_table")),
        tabPanel("Analysis", tableOutput("summary_table"))
      )
    )
  )
)

server <- function(input, output, session) {
  
  uploaded_data <- reactive({
    req(input$csv_file)
    
    read.csv(
      input$csv_file$datapath,
      header = input$header,
      sep = input$sep,
      stringsAsFactors = FALSE
    )
  })
  
  # Dynamically create column selector
  output$column_selector <- renderUI({
    req(uploaded_data())
    
    selectInput(
      "selected_columns",
      "Select columns for analysis:",
      choices = names(uploaded_data()),
      selected = names(uploaded_data())[1],
      multiple = TRUE
    )
  })
  
  # Data table view
  output$data_table <- renderDT({
    datatable(
      uploaded_data(),
      options = list(
        pageLength = 10,
        scrollX = TRUE
      )
    )
  })
  
  # Analysis (summary stats)
  output$summary_table <- renderTable({
    req(input$selected_columns)
    
    data <- uploaded_data()[, input$selected_columns, drop = FALSE]
    
    summary(data)
  })
}

shinyApp(ui, server)
